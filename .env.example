# Build-time (PUBLIC_ prefix = available in client-side code)
PUBLIC_GTM_ID=GTM-XXXXXXX
PUBLIC_TURNSTILE_SITE_KEY=0x...   # Cloudflare dashboard → Turnstile → add site

# Runtime (Cloudflare Pages → Settings → Environment variables)
# Local dev: put these in .dev.vars (gitignored)
RESEND_API_KEY=re_...
CONTACT_TO=hallo@yourdomain.ch
CONTACT_FROM=forms@yourdomain.ch   # must be a verified Resend sending domain
CONTACT_BCC=                       # optional — BCC address for every submission
TURNSTILE_SECRET=0x...             # Cloudflare dashboard → Turnstile → secret key
