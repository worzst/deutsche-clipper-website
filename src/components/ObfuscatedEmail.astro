---
// Renders an email link without ever writing the address in the HTML source.
// The mailto: href is assembled in the browser on first interaction — static
// scrapers never see it. Used wherever an email address must appear on-page.
interface Props {
  email: string;
  class?: string;
}
const { email, class: className } = Astro.props;

const [user, domain] = email.split('@');
const userRev = user.split('').reverse().join('');
const domainRev = domain.split('').reverse().join('');
const id = `em-${Math.random().toString(36).slice(2, 8)}`;
---

<a id={id} href="#" class={className} data-u={userRev} data-d={domainRev}></a>

<script is:inline define:vars={{ id }}>
  const el = document.getElementById(id);
  if (el) {
    const u = el.dataset.u.split('').reverse().join('');
    const d = el.dataset.d.split('').reverse().join('');
    const addr = u + '@' + d;
    el.textContent = addr;
    el.href = 'mailto:' + addr;
  }
</script>
