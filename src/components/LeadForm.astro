---
import Turnstile from './Turnstile.astro';

type InputType = 'text' | 'email' | 'tel' | 'url' | 'number';

type Field =
  | { type: InputType; name: string; placeholder?: string; required?: boolean }
  | { type: 'textarea'; name: string; placeholder?: string; rows?: number; required?: boolean }
  | { type: 'radios'; name: string; options: string[] }
  | { type: 'select'; name: string; options: string[]; placeholder?: string };

interface Props {
  id: string;
  source: string;
  fields: Field[];
  action?: string;
  submitLabel?: string;
  submitVariant?: 'accent' | 'ink';
  successTitle?: string;
  successBody?: string;
  errorHtml?: string;
  theme?: 'light' | 'dark';
  turnstileTheme?: 'light' | 'dark' | 'auto';
}

const {
  id,
  source,
  fields,
  action = '/contact',
  submitLabel = 'Absenden',
  submitVariant = 'accent',
  successTitle = 'Danke!',
  successBody = 'Wir melden uns bald bei Ihnen.',
  errorHtml = 'Etwas ist schiefgelaufen. Bitte versuchen Sie es erneut.',
  theme = 'light',
  turnstileTheme = 'auto',
} = Astro.props;

const formId = `${id}Form`;
const successId = `${id}Success`;
const errorId = `${id}Error`;
const labelId = `${id}Label`;
---

<div
  class:list={['lf', `lf--${theme}`]}
  data-form-id={formId}
  data-success-id={successId}
  data-error-id={errorId}
  data-label-id={labelId}
  data-submit-label={submitLabel}
>
  <div id={successId} class="lf-success flex-col items-center gap-4 text-center py-8">
    <div class="w-14 h-14 rounded-full bg-success text-ink flex items-center justify-center text-2xl font-bold">✓</div>
    <h3 class="text-[26px] font-bold m-0">{successTitle}</h3>
    <p class="m-0 opacity-70">{successBody}</p>
  </div>

  <form id={formId} class="grid gap-3" action={action} method="POST">
    <input
      class="lf-hp absolute left-[-9999px] opacity-0 pointer-events-none"
      type="text"
      name="_hp"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />
    <input type="hidden" name="_source" value={source} />

    {
      fields.map((field) => {
        if (field.type === 'textarea') {
          return (
            <textarea
              class="lf-field rounded-2xl resize-none"
              name={field.name}
              placeholder={field.placeholder}
              rows={field.rows ?? 4}
              required={field.required}
            />
          );
        }
        if (field.type === 'radios') {
          return (
            <div class="flex gap-2 flex-wrap">
              {field.options.map((opt) => (
                <label class="lf-radio-label inline-flex items-center px-4 py-2.5 rounded-full border border-[var(--lf-radio-border)] text-[13px] cursor-pointer text-[var(--lf-radio-color)] transition-colors duration-200 has-[:checked]:bg-[var(--lf-radio-checked-bg)] has-[:checked]:border-[var(--lf-radio-checked-border)]">
                  <input type="radio" name={field.name} value={opt} class="sr-only" />
                  &nbsp;{opt}
                </label>
              ))}
            </div>
          );
        }
        if (field.type === 'select') {
          return (
            <select class="lf-field appearance-none cursor-pointer rounded-full">
              {field.placeholder && <option value="">{field.placeholder}</option>}
              {field.options.map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          );
        }
        return (
          <input
            class="lf-field rounded-full"
            type={field.type}
            name={field.name}
            placeholder={field.placeholder}
            required={field.required}
          />
        );
      })
    }

    <Turnstile theme={turnstileTheme} />

    <button type="submit" class:list={['lf-submit', `lf-submit--${submitVariant}`]}>
      <span id={labelId}>{submitLabel}</span>
      <span aria-hidden="true">→</span>
    </button>
    <slot name="after-submit" />
    <p id={errorId} class="lf-error text-[13px] leading-relaxed m-0" set:html={errorHtml} />
  </form>
</div>

<style>
  /* ── Light theme ── */
  .lf--light {
    --lf-field-bg: transparent;
    --lf-field-border: rgba(0, 0, 0, 0.15);
    --lf-field-color: var(--color-ink);
    --lf-placeholder: var(--color-mute);
    --lf-focus-border: var(--color-accent);
    --lf-radio-border: rgba(0, 0, 0, 0.15);
    --lf-radio-color: var(--color-ink);
    --lf-radio-checked-bg: rgba(0, 0, 0, 0.06);
    --lf-radio-checked-border: var(--color-ink);
    --lf-success-color: var(--color-ink);
    --lf-error-color: var(--color-error);
  }

  /* ── Dark theme ── */
  .lf--dark {
    --lf-field-bg: rgba(255, 255, 255, 0.06);
    --lf-field-border: rgba(255, 255, 255, 0.15);
    --lf-field-color: #fff;
    --lf-placeholder: rgba(255, 255, 255, 0.4);
    --lf-focus-border: rgba(255, 255, 255, 0.5);
    --lf-radio-border: rgba(255, 255, 255, 0.18);
    --lf-radio-color: #fff;
    --lf-radio-checked-bg: rgba(255, 255, 255, 0.12);
    --lf-radio-checked-border: rgba(255, 255, 255, 0.6);
    --lf-success-color: #fff;
    --lf-error-color: #ff8f80;
  }

  /* Field base — shared between input, textarea, select */
  .lf-field {
    padding: 15px 20px;
    border: 1.5px solid var(--lf-field-border);
    background: var(--lf-field-bg);
    color: var(--lf-field-color);
    font-size: 15px;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
  }
  .lf-field:focus {
    border-color: var(--lf-focus-border);
  }
  .lf-field::placeholder {
    color: var(--lf-placeholder);
  }

  /* Submit button */
  .lf-submit {
    padding: 16px 24px;
    border-radius: 999px;
    border: none;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    transition: opacity 0.2s;
  }
  .lf-submit:disabled {
    opacity: 0.5;
    cursor: default;
  }
  .lf-submit--accent {
    background: var(--color-accent);
    color: #fff;
  }
  .lf-submit--ink {
    background: var(--color-ink);
    color: #fff;
  }

  /* Success state */
  .lf-success {
    display: none;
  }
  .lf-success.show {
    display: flex;
  }

  /* Error */
  .lf-error {
    display: none;
    color: var(--lf-error-color);
  }
  .lf-error.show {
    display: block;
  }
</style>

<script>
  import { wireForm } from '../scripts/formSubmit';
  document.querySelectorAll<HTMLElement>('[data-form-id]').forEach((el) => {
    const { formId, successId, errorId, labelId, submitLabel } = el.dataset;
    if (formId && successId && errorId && labelId && submitLabel) {
      wireForm(formId, successId, errorId, labelId, submitLabel);
    }
  });
</script>
