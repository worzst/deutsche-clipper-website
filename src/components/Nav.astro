---
import Logo from './Logo.astro';

interface Props {
  page: 'clipper' | 'creator';
}
const { page } = Astro.props;

const crossLink =
  page === 'clipper'
    ? { href: '/creator', label: 'Für Creator →' }
    : { href: '/', label: 'Für Clipper →' };
---

<header class="dc-nav" id="dcNav">
  <div class="dc-nav-inner">
    <Logo />
    <div class="dc-nav-right">
      <a href={crossLink.href} class="dc-nav-link">{crossLink.label}</a>
      <a href="#waitlist" class="dc-nav-beta">Beta-Zugang</a>
    </div>
  </div>
</header>

<style>
  .dc-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    padding: 0 40px;
    display: flex;
    align-items: center;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      backdrop-filter 0.3s ease;
  }
  .dc-nav.scrolled {
    background: rgba(8, 8, 8, 0.92);
    backdrop-filter: blur(12px);
    border-color: rgba(255, 255, 255, 0.06);
  }
  .dc-nav-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .dc-nav-right {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .dc-nav-link {
    color: rgba(255, 255, 255, 0.5);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    transition: color 0.2s;
  }
  .dc-nav-link:hover {
    color: #fff;
  }
  .dc-nav-beta {
    background: var(--dc-accent);
    color: var(--dc-accent-text);
    padding: 8px 20px;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .dc-nav-beta:hover {
    opacity: 0.85;
  }
  @media (max-width: 480px) {
    .dc-nav {
      padding: 0 20px;
    }
    .dc-nav-link {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById('dcNav')!;
  window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 40), {
    passive: true,
  });
</script>
