---
interface Props {
  label?: string;
  heading: string;
  headingEm?: string;
  align?: 'left' | 'center';
  size?: 'sm' | 'md' | 'lg';
  mb?: number;
}
const { label, heading, headingEm, align = 'center', size = 'md', mb = 56 } = Astro.props;

const headingSize = {
  sm: 'text-[clamp(28px,4vw,56px)]',
  md: 'text-[clamp(36px,5.5vw,72px)]',
  lg: 'text-[clamp(44px,7vw,96px)]',
}[size];
---

<div class:list={['reveal', align === 'center' ? 'text-center' : 'text-left']} style={`margin-bottom:${mb}px`}>
  {label && <div class="font-mono text-[11px] font-semibold text-mute uppercase tracking-[0.1em] mb-4">{label}</div>}
  <h2 class:list={['font-extrabold leading-[0.95] tracking-[-0.04em] text-ink m-0', headingSize]}>
    {heading}
    {
      headingEm && (
        <>
          <br />
          <em class="italic text-accent">{headingEm}</em>
        </>
      )
    }
  </h2>
</div>
