---
import Logo from './Logo.astro';
import { SITE_NAME } from '../config';

interface Props {
  page: 'clipper' | 'creator';
}
const { page } = Astro.props;

const crossLink =
  page === 'clipper'
    ? { href: '/creator', label: 'Für Creator' }
    : { href: '/', label: 'Für Clipper' };
---

<footer class="dc-footer">
  <Logo size={22} />
  <nav class="dc-footer-links" aria-label="Footer-Navigation">
    <a href={crossLink.href}>{crossLink.label}</a>
    <a href="/impressum">Impressum</a>
    <a href="/datenschutz">Datenschutz</a>
  </nav>
  <p class="dc-footer-copy">© {new Date().getFullYear()} {SITE_NAME}</p>
</footer>

<style>
  .dc-footer {
    padding: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }
  .dc-footer-links {
    display: flex;
    gap: 32px;
  }
  .dc-footer-links a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.2s;
  }
  .dc-footer-links a:hover {
    color: rgba(255, 255, 255, 0.7);
  }
  .dc-footer-copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.2);
    margin: 0;
  }
  @media (max-width: 640px) {
    .dc-footer {
      flex-direction: column;
      align-items: flex-start;
      padding: 32px 20px;
    }
    .dc-footer-links {
      flex-wrap: wrap;
      gap: 20px;
    }
  }
</style>
