---
import { SITE_NAME, PHONE, PHONE_HREF, EMAIL, ADDRESS_STREET, ADDRESS_CITY } from '../config';
import ObfuscatedEmail from './ObfuscatedEmail.astro';
---

<footer class="bg-ink text-paper pt-16">
  <div class="footer-inner">
    <div>
      <span class="block text-lg font-extrabold tracking-[-0.04em] mb-3">{SITE_NAME}</span>
      <address class="not-italic text-sm leading-relaxed text-white/50">
        {ADDRESS_STREET}<br />
        {ADDRESS_CITY}
      </address>
    </div>

    <div class="flex flex-col gap-2.5 pt-1">
      <a href={PHONE_HREF} class="text-sm text-white/55 hover:text-white transition-colors">{PHONE}</a>
      <ObfuscatedEmail email={EMAIL} class="text-sm text-white/55 hover:text-white transition-colors" />
    </div>

    <nav class="flex flex-col gap-2.5 pt-1" aria-label="Rechtliches">
      <a href="/impressum" class="text-sm text-white/55 hover:text-white transition-colors">Impressum</a>
      <a href="/datenschutz" class="text-sm text-white/55 hover:text-white transition-colors">Datenschutz</a>
    </nav>
  </div>

  <div class="footer-bottom">
    <p class="text-xs text-white/30">&copy; {new Date().getFullYear()} {SITE_NAME}</p>
  </div>
</footer>

<style>
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter) 48px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 20px var(--gutter);
  }
  .footer-bottom p {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
