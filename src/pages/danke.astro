---
// Post-form redirect target — alternative to the inline AJAX success state.
// Use this when the contact form POSTs to a server route that redirects here,
// rather than using the default AJAX submit in LeadForm.
// Redirect after form submit (server-side): return Response.redirect('/danke', 303)
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME } from '../config';
---

<Layout title={`Vielen Dank — ${SITE_NAME}`} noindex={true}>
  <Nav />
  <section class="min-h-[70vh] flex items-center justify-center px-[var(--gutter)] py-[var(--section-pad)]">
    <div class="max-w-[480px] text-center">
      <div
        class="w-16 h-16 rounded-full bg-success text-ink flex items-center justify-center text-[28px] font-bold mx-auto mb-8"
      >
        ✓
      </div>
      <h1 class="text-[clamp(28px,4vw,44px)] font-extrabold tracking-[-0.03em] text-ink m-0 mb-4">
        Vielen Dank für Ihre Anfrage!
      </h1>
      <p class="text-[17px] text-mute leading-relaxed m-0 mb-10">
        Wir haben Ihre Nachricht erhalten und melden uns innerhalb eines Werktages bei Ihnen.
      </p>
      <a
        href="/"
        class="inline-flex items-center leading-none px-7 py-[14px] rounded-full bg-accent text-white text-[15px] font-semibold hover:opacity-85 transition-opacity"
      >
        Zurück zur Startseite
      </a>
    </div>
  </section>
  <Footer />
</Layout>
