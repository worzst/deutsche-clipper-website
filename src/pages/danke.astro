---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME } from '../config';
---

<Layout title={`Vielen Dank — ${SITE_NAME}`} noindex={true} accentColor="#FFCC00" accentTextColor="#080808">
  <Nav page="clipper" />
  <section class="page-center">
    <div class="page-box">
      <div class="success-check">✓</div>
      <h1 class="page-title">Vielen Dank!</h1>
      <p class="page-body">Wir haben deine Anmeldung erhalten und melden uns in Kürze bei dir.</p>
      <a href="/" class="btn-home">Zurück zur Startseite</a>
    </div>
  </section>
  <Footer page="clipper" />
</Layout>

<style>
  .page-center {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--section-pad) var(--gutter);
  }
  .page-box {
    max-width: 480px;
    text-align: center;
  }
  .success-check {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-success);
    color: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    margin: 0 auto 32px;
  }
  .page-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 16px;
  }
  .page-body {
    font-size: 17px;
    color: var(--color-mute);
    line-height: 1.6;
    margin: 0 0 40px;
  }
  .btn-home {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    padding: 14px 28px;
    border-radius: 9999px;
    background: var(--dc-accent);
    color: var(--dc-accent-text);
    font-size: 15px;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .btn-home:hover {
    opacity: 0.85;
  }
</style>
