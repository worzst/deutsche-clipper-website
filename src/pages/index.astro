---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const benefits = [
  {
    icon: '💸',
    title: 'Pay-per-View',
    desc: 'Keine Pauschalbeträge. Du verdienst direkt proportional zu deinen Views. Mehr Qualität und Reichweite = mehr Geld.',
  },
  {
    icon: '🎯',
    title: 'Echte Creator',
    desc: 'Keine Fake-Anfragen. Nur verifizierte deutsche Creator mit aktivem Publikum.',
  },
  {
    icon: '⚡',
    title: 'Schnelle Auszahlung',
    desc: 'Wöchentliche Auszahlungen. Direkt auf dein Konto. Keine monatelangen Wartezeiten.',
  },
  {
    icon: '🔒',
    title: 'Rechtlich sicher',
    desc: 'Klare Verträge, DSGVO-konform. Du bist abgesichert von beiden Seiten.',
  },
];
---

<Layout
  title="Deutsche Clipper — Für Clipper | Geld verdienen mit Clips"
  description="Werde bezahlter Clipper für die größten deutschen Creator. Verdiene pro 1.000 Views — direkt, transparent, ohne Bullshit."
  accentColor="#FFCC00"
  accentTextColor="#080808"
>
  <Nav page="clipper" />

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="grid-bg"></div>
    <div class="glow"></div>

    <div class="hero-inner">
      <div class="tag anim-0">Clipper Beta 2026</div>

      <h1 class="h1 anim-1">
        CLIP IT.<br />
        <span class="h1-gold">CASH</span><span class="h1-outline"> IT.</span>
      </h1>

      <div class="subtext anim-2">
        <p class="subtext-left">
          Werde bezahlter Clipper für die größten deutschen Creator. Du schneidest. Wir rechnen ab.
        </p>
        <p class="subtext-right">
          Verdiene <strong>pro 1.000 Views</strong>: direkt, transparent, und ohne Bullshit.
        </p>
      </div>

      <div class="cta anim-3">
        <a href="#waitlist" class="btn-primary">Jetzt zur Beta anmelden</a>
        <span class="cta-hint">Kostenlos · Kein Spam</span>
      </div>

      <div class="stats anim-4">
        <div class="stat">
          <div class="stat-val">€0,50–3,00</div>
          <div class="stat-lbl">pro 1.000 Views</div>
          <div class="stat-sub">je nach Creator</div>
        </div>
        <div class="stat">
          <div class="stat-val">100%</div>
          <div class="stat-lbl">Remote</div>
          <div class="stat-sub">Clip von überall</div>
        </div>
        <div class="stat">
          <div class="stat-val">∞</div>
          <div class="stat-lbl">Creator</div>
          <div class="stat-sub">wachsendes Netzwerk</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ── -->
  <section class="dc-section">
    <div class="dc-inner">
      <div class="reveal">
        <div class="dc-label">So funktioniert's</div>
        <h2 class="dc-h2">IN DREI SCHRITTEN<br /><span class="dc-hl">ZUM EARNING</span></h2>
      </div>

      <div class="steps-grid">
        <div class="step step--accent-top reveal">
          <div class="step-ghost">01</div>
          <div class="step-num dc-hl">01</div>
          <h3 class="step-title">Creator aussuchen</h3>
          <p class="step-body">Durchsuche Creator, die aktiv Clipper suchen. Bewirb dich kostenlos auf ihre Kanäle.</p>
        </div>
        <div class="step step--bg reveal" data-delay="100">
          <div class="step-ghost">02</div>
          <div class="step-num dc-hl">02</div>
          <h3 class="step-title">Clips erstellen</h3>
          <p class="step-body">
            Schneid die besten Momente aus dem Content. Short-Form für TikTok, Reels und YouTube Shorts.
          </p>
        </div>
        <div class="step reveal" data-delay="200">
          <div class="step-ghost">03</div>
          <div class="step-num dc-hl">03</div>
          <h3 class="step-title">Geld verdienen</h3>
          <p class="step-body">
            Pro 1.000 Views erhältst du direkt deine Vergütung. Automatisch und transparent auf dein Konto.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── BENEFITS ── -->
  <section class="dc-section dc-section--alt">
    <div class="dc-inner">
      <div class="benefits-header reveal">
        <h2 class="dc-h2">WARUM<br /><span class="dc-hl">DEUTSCHE CLIPPER</span>?</h2>
        <p class="benefits-desc">
          Die erste Plattform, die deutsche Clipper mit deutschen Creatorn professionell zusammenbringt.
        </p>
      </div>

      <div class="benefits-grid">
        {
          benefits.map((b, i) => (
            <div class:list={['benefit-card', 'reveal']} data-delay={i % 2 === 1 ? '100' : undefined}>
              <div class="benefit-icon">{b.icon}</div>
              <h3 class="benefit-title">{b.title}</h3>
              <p class="benefit-body">{b.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── WAITLIST ── -->
  <section id="waitlist" class="dc-section">
    <div class="dc-inner">
      <div class="waitlist-grid">
        <div class="reveal">
          <div class="dc-label">Limitierte Beta-Plätze</div>
          <h2 class="dc-h2 dc-h2--lg">SICHERE DEINEN<br /><span class="dc-hl">PLATZ</span></h2>
          <p class="waitlist-copy">
            Sei einer der ersten Clipper auf der Plattform beim Launch. Beta-Nutzer erhalten exklusiven Zugang zu
            Premium-Creatorn und erhöhten Vergütungen.
          </p>
        </div>

        <div class="reveal" data-delay="100">
          <form id="clipperForm" action="/waitlist" method="POST" class="waitlist-form">
            <input type="text" name="_hp" class="dc-hp" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_source" value="Clipper Waitlist" />

            <input type="email" name="email" placeholder="deine@email.de" required class="email-input" />
            <button type="submit" class="email-btn">
              <span id="clipperLabel">Als Clipper anmelden</span>
            </button>

            <p class="form-disclaimer">Kein Spam. Keine Kosten. Jederzeit abmeldbar.</p>

            <div class="cross-link-block">
              <p class="cross-link-label">DU BIST EIN CREATOR?</p>
              <a href="/creator" class="cross-link">Zur Creator-Anmeldung →</a>
            </div>

            <p id="clipperError" class="form-error">Etwas ist schiefgelaufen. Bitte versuche es erneut.</p>
          </form>

          <div id="clipperSuccess" class="form-success">
            <div class="success-title">🎉 DU BIST DRIN!</div>
            <p class="success-body">
              Wir haben dich auf die Waitlist gesetzt. Du erhältst eine E-Mail sobald wir die Beta für Clipper öffnen.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer page="clipper" />
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 100px var(--gutter) 80px;
  }
  .grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .glow {
    position: absolute;
    top: 20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, color-mix(in srgb, var(--dc-accent) 13%, transparent) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
    animation: dc-pulse 4s ease-in-out infinite;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* staggered entrance animations */
  .anim-0 {
    animation: dc-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .anim-1 {
    animation: dc-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .anim-2 {
    animation: dc-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }
  .anim-3 {
    animation: dc-fade-up 0.8s ease 0.45s both;
  }
  .anim-4 {
    animation: dc-fade-up 0.8s ease 0.6s both;
  }

  .tag {
    display: inline-block;
    background: var(--dc-accent);
    color: var(--dc-accent-text);
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    padding: 6px 14px;
    margin-bottom: 28px;
    text-transform: uppercase;
  }

  .h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 12vw, 180px);
    line-height: 0.9;
    letter-spacing: 2px;
    color: #f0f0f0;
    margin: 0;
  }
  .h1-gold {
    color: var(--dc-accent);
  }
  .h1-outline {
    -webkit-text-stroke: clamp(4px, 0.44vw, 8px) #f0f0f0;
    color: #080808;
    paint-order: stroke fill;
  }

  .subtext {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 760px;
    margin-top: 32px;
  }
  .subtext p {
    font-size: 20px;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }
  .subtext-left {
    padding-right: 40px;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }
  .subtext-right {
    padding-left: 40px;
  }
  .subtext strong {
    color: var(--dc-accent);
    font-weight: 600;
  }

  .cta {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .btn-primary {
    background: var(--dc-accent);
    color: var(--dc-accent-text);
    padding: 16px 36px;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.5px;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: opacity 0.15s;
    display: inline-block;
  }
  .btn-primary:hover {
    opacity: 0.9;
  }
  .cta-hint {
    color: rgba(255, 255, 255, 0.3);
    font-size: 14px;
  }

  .stats {
    margin-top: 72px;
    display: flex;
    gap: 60px;
    flex-wrap: wrap;
  }
  .stat-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 40px;
    color: var(--dc-accent);
    letter-spacing: 1px;
  }
  .stat-lbl {
    font-size: 13px;
    color: #f0f0f0;
    font-weight: 600;
    margin-top: 2px;
  }
  .stat-sub {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 2px;
  }

  /* ── Shared section helpers ── */
  .dc-section {
    padding: var(--section-pad) 0;
  }
  .dc-section--alt {
    background: rgba(255, 255, 255, 0.015);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .dc-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .dc-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 4px;
    color: var(--dc-accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .dc-h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 80px);
    letter-spacing: 2px;
    color: #f0f0f0;
    line-height: 0.95;
    margin: 0 0 64px;
  }
  .dc-h2--lg {
    font-size: clamp(56px, 6vw, 96px);
  }
  .dc-hl {
    color: var(--dc-accent);
  }

  /* ── How it works ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .step {
    padding: 48px 40px;
    position: relative;
    border-top: 3px solid rgba(255, 255, 255, 0.08);
  }
  .step--accent-top {
    border-top-color: var(--dc-accent);
  }
  .step--bg {
    background: rgba(255, 255, 255, 0.03);
  }
  .step-ghost {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 72px;
    color: rgba(255, 255, 255, 0.05);
    position: absolute;
    top: 20px;
    right: 24px;
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .step-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 1px;
    color: #f0f0f0;
    margin: 0 0 16px;
    line-height: 1.1;
  }
  .step-body {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
  }

  /* ── Benefits ── */
  .benefits-header {
    margin-bottom: 64px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
  }
  .benefits-header .dc-h2 {
    margin-bottom: 0;
  }
  .benefits-desc {
    max-width: 320px;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }
  .benefit-card {
    padding: 40px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(8, 8, 8, 0.8);
    transition:
      border-color 0.2s,
      background 0.2s;
  }
  .benefit-card:hover {
    border-color: color-mix(in srgb, var(--dc-accent) 40%, transparent);
    background: color-mix(in srgb, var(--dc-accent) 5%, transparent);
  }
  .benefit-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }
  .benefit-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    color: #f0f0f0;
    margin: 0 0 12px;
  }
  .benefit-body {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
  }

  /* ── Waitlist ── */
  .waitlist-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .waitlist-copy {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    font-weight: 300;
    max-width: 380px;
    margin: 0;
  }
  .waitlist-form {
    position: relative;
  }
  .email-input {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    outline: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: #f0f0f0;
    padding: 14px 18px;
    transition: border-color 0.2s;
  }
  .email-input:focus {
    border-color: var(--dc-accent);
  }
  .email-input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }
  .email-btn {
    width: 100%;
    background: var(--dc-accent);
    color: var(--dc-accent-text);
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 18px;
    letter-spacing: 0.4px;
    margin-top: 12px;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: opacity 0.15s;
  }
  .email-btn:hover {
    opacity: 0.85;
  }
  .email-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .form-disclaimer {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.25);
    margin: 12px 0 0;
    font-weight: 300;
  }
  .cross-link-block {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .cross-link-label {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.3);
    margin: 0 0 20px;
    letter-spacing: 0.3px;
  }
  .cross-link {
    color: #e30613;
    font-size: 15px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.2s;
  }
  .cross-link:hover {
    gap: 14px;
  }
  .form-error {
    display: none;
    font-size: 13px;
    color: rgba(255, 100, 100, 0.9);
    margin-top: 12px;
  }
  .form-error.show {
    display: block;
  }
  .form-success {
    display: none;
    border: 1px solid color-mix(in srgb, var(--dc-accent) 27%, transparent);
    background: color-mix(in srgb, var(--dc-accent) 4%, transparent);
    padding: 40px;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  }
  .form-success.show {
    display: block;
  }
  .success-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--dc-accent);
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .success-body {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
    .benefits-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .waitlist-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
  @media (max-width: 640px) {
    .subtext {
      grid-template-columns: 1fr;
    }
    .subtext-left {
      padding-right: 0;
      border-right: none;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    .subtext-right {
      padding-left: 0;
      padding-top: 20px;
    }
    .benefits-grid {
      grid-template-columns: 1fr;
    }
    .stats {
      gap: 32px;
    }
    .cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  import { wireForm } from '../scripts/formSubmit';
  wireForm('clipperForm', 'clipperSuccess', 'clipperError', 'clipperLabel', 'Als Clipper anmelden');
</script>
